@model IEnumerable<DAPMDuLich.Models.TourDuLich>

@{
    ViewBag.Title = "Danh Sách";
    Layout = "~/Areas/Contributors/Views/Shared/_Layout.cshtml";
    int i = 0;
}

<!-- Wrapper để chứa canvas và các phần tử dữ liệu -->
<div class="content-wrapper">
    <!-- Canvas cho hiệu ứng tuyết -->
    <canvas id="projector"></canvas>

    <div class="row" style="margin-top:50px; position: relative;">
        <!-- Thêm position relative -->
        <div class="col-md-12">
            <h3>DANH SÁCH ĐĂNG BÀI TOUR</h3>
        </div>
        <div class="row" style="margin-top:20px;">
            <div class="col-md-12 text-center">
                <form action="@Url.Action("Search", "Tour", new { area = "Contributors" })" method="get" class="d-flex flex-row align-items-stretch justify-content-center" style="gap: 15px; flex-wrap: nowrap; margin-bottom: 30px;">
                    <!-- Ô tìm kiếm Tên tour + Địa điểm -->
                    <input type="text" id="tourLocationSearch" name="tourLocationSearch" class="form-control"
                           style="width: 15%; height: 50px; font-size: 16px; border-radius: 25px; padding-left: 20px;"
                           placeholder="Tên tour hoặc Địa điểm" autocomplete="off" />

                    <!-- Ô chọn ngày khởi hành và kết thúc -->
                    <div class="date-row" style="display: flex; align-items: center; gap: 10px;">
                        <label for="startDate" style="margin-right: 5px; white-space: nowrap;">Ngày đi:</label>
                        <input type="date" id="startDate" name="startDate" class="form-control"
                               style="width: 150px; height: 50px; font-size: 16px; border-radius: 25px;" />

                        <label for="endDate" style="margin-left: 15px; margin-right: 5px; white-space: nowrap;">Ngày kết thúc:</label>
                        <input type="date" id="endDate" name="endDate" class="form-control"
                               style="width: 150px; height: 50px; font-size: 16px; border-radius: 25px;" />
                    </div>

                    <!-- Loại tour -->
                    <select name="idLoaiTour" class="form-control" style="width: 15%; height: 50px; font-size: 16px; border-radius: 25px; padding-left: 20px;">
                        <option value="">Loại tour</option>
                        @foreach (var item in new DAPMDuLich.Models.mapLoaiTour().DanhSach())
                        {
                            <option value="@item.ID" @Html.Raw(item.ID == (int?)ViewBag.idLoaiTour ? "selected" : "")>@item.Ten</option>
                        }
                    </select>

                    <!-- Mức giá -->
                    <select name="idMucGia" class="form-control" style="width: 15%; height: 50px; font-size: 16px; border-radius: 25px; padding-left: 20px;">
                        <option value="">Tất cả mức giá</option>
                        @foreach (var item in new DAPMDuLich.Models.mapMucGia().DanhSach())
                        {
                            <option value="@item.ID" @Html.Raw(item.ID == (int?)ViewBag.idMucGia ? "selected" : "")>@item.Gia</option>
                        }
                    </select>

                    <!-- Button Tìm kiếm -->
                    <button type="submit" class="btn btn-primary" style="width: 10%; height: 50px; font-size: 16px; border-radius: 25px; margin: 0;">
                        Tìm kiếm
                    </button>
                </form>

                <!-- Gợi ý tìm kiếm -->
                <div id="searchSuggestions" style="display:none; position: absolute; width: 100%; background-color: white; border: 1px solid #ccc; z-index: 999;"></div>
            </div>
        </div>

        <div class="col-md-12">
            <table class="table table-bordered ">
                <tr>
                    <th>STT</th>
                    <th>Tên tour</th>
                    <th>Địa điểm</th>
                    <th>Ngày đi</th>
                    <th>Ngày kết thúc</th>
                    <th>Số người tối đa</th>
                    <th>Loại tour</th>
                    <th>Phương tiện</th>
                    <th>Giá tour</th>
                    <th>Trạng thái chờ duyệt</th>
                    <th>#</th>
                </tr>

                @foreach (var item in Model)
                {
                    i++;
                    <tr>
                        <td>@i</td>
                        <td>@item.TieuDe</td>
                        <td>@item.DiaDiem</td>
                        <td>@item.TripStart</td>
                        <td>@item.TripEnd</td>
                        <td>@item.SoNguoiToiDa</td>
                        <td>
                            @{
                                var loaiTour = new DAPMDuLich.Models.mapLoaiTour().ChiTiet(item.idLoaiTour ?? 0);
                                if (loaiTour != null)
                                {
                                    <span>@loaiTour.Ten</span>
                                }
                            }
                        </td>
                        <td>@item.PhuongTien</td>
                        <td>
                            @(item.GiaTour.HasValue
                                ? (item.GiaTour.Value % 1 == 0
                                    ? item.GiaTour.Value.ToString("F0")  // Nếu là số nguyên, hiển thị phần nguyên
                                    : item.GiaTour.Value.ToString("0.####"))  // Nếu có phần thập phân, hiển thị tối đa 4 chữ số thập phân, không hiển thị nếu không có
                                : "0") USD
                        </td>
                        <td>
                            @if (item.Status == "N")
                            {
                                <span>Đang chờ duyệt bài...</span>
                            }
                            else if (item.Status == "A")
                            {
                                <span style="color: green;">Đã duyệt bài <i class="fa fa-check"></i></span>
                            }
                            else if (item.Status == "R")
                            {
                                <span style="color: red;">Đã từ chối duyệt bài <i class="fa fa-times"></i></span>
                                <div>Lí Do Từ Chối: @item.RejectionNote</div>
                            }
                        </td>
                        <td>
                            @Html.ActionLink("Cập nhật", "Update", new { id = item.ID }, new { @class = "btn btn-primary" })
                            @*<button type="button" class="btn btn-icon btn-round btn-danger btn-xs" style="margin-left: 10px;"
                                    onclick="if (confirm('Có muốn xóa không?')) {
                                    location.href='@Url.Action("Delete", "Tour", new { area = "Contributors", id = item.ID })' }">
                                <i class="fa fa-trash" aria-hidden="true"></i>
                            </button>*@
                        </td>
                    </tr>
                }
            </table>
        </div>
    </div>
</div>

<style>
    /* Đảm bảo canvas không bao phủ góc bên trái */
    #projector {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -1; /* Đảm bảo canvas nằm dưới tất cả các phần tử */
        pointer-events: none; /* Canvas không chặn các sự kiện chuột */
    }
    .container {
        position: relative;
        z-index: 2; /* Đảm bảo nội dung luôn nằm trên canvas */
    }

    .content-wrapper {
        position: relative;
        z-index: 2;
    }
    .date-row {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .content-wrapper {
        position: relative;
        z-index: 2;
    }
</style>

<script>
    var canvas, ctx, snowflakes = [];

    function setupCanvas() {
        canvas = document.getElementById("projector");
        ctx = canvas.getContext("2d");

        // Thiết lập chiều rộng và chiều cao cho canvas
        canvas.width = window.innerWidth - 200; // Chừa lại phần bên trái
        canvas.height = window.innerHeight;

        // Tạo các bông tuyết
        for (var i = 0; i < 30; i++) {
            snowflakes.push(createSnowflake());
        }

        animateSnowflakes();
    }

    // Hàm tạo một bông tuyết
    function createSnowflake() {
        return {
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            size: Math.random() * 15 + 10,
            alpha: Math.random() * 0.5 + 0.3,
            speedY: Math.random() * 1 + 0.5,
            speedX: Math.random() * 0.5 - 0.25,
            icon: "❄️"
        };
    }

    // Cập nhật vị trí các bông tuyết và vẽ chúng
    function updateSnowflakes() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        snowflakes.forEach(function (snowflake) {
            snowflake.y += snowflake.speedY;

            // Reset vị trí bông tuyết khi ra ngoài màn hình
            if (snowflake.y > canvas.height) {
                snowflake.y = -snowflake.size;
                snowflake.x = Math.random() * canvas.width;
            }

            snowflake.x += snowflake.speedX;

            if (snowflake.x > canvas.width) snowflake.x = 0;
            if (snowflake.x < 0) snowflake.x = canvas.width;

            // Vẽ bông tuyết
            ctx.fillStyle = "#FFFFFF";
            ctx.font = snowflake.size + "px Arial";
            ctx.globalAlpha = snowflake.alpha;
            ctx.fillText(snowflake.icon, snowflake.x, snowflake.y);
        });
    }

    // Animation cho tuyết
    function animateSnowflakes() {
        updateSnowflakes();
        requestAnimationFrame(animateSnowflakes);
    }

    // Khởi tạo tuyết khi tải xong trang
    window.onload = setupCanvas;
</script>
