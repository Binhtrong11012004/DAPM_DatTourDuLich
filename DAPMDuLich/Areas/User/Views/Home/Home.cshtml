@model List<DAPMDuLich.Models.TourDuLich>
@{
    ViewBag.Title = "Home";
    Layout = "~/Areas/User/Views/Shared/LayoutCus.cshtml";
}

<link rel="stylesheet" href="~/CSS/animate.css" />
<link rel="stylesheet" href="~/CSS/bootstrap.css" />
<link rel="stylesheet" href="~/CSS/icomoon.css" />
<link rel="stylesheet" href="~/CSS/owl.carousel.min.css" />
<link rel="stylesheet" href="~/CSS/owl.theme.default.min.css" />
<link rel="stylesheet" href="~/CSS/style.css" />

<!-- Phần nội dung chung -->
<div class="contenner">
    <!-- Tim Kiem -->
    <div class="col-12" style="padding: 10px 100px;">
        <div class="col-12" style="padding: 10px; box-shadow: rgba(0, 0, 0, 0.24) 0px 3px 8px;">
         <form action="@Url.Action("SearchTour", "Home", new { area = "User" })" method="get" style="display: flex; align-items: center;">
                <!-- Loại tour -->
                <div class="col-2" style="padding: 0px 10px; flex: 1;">
                    <select style="width: 100%; height: 35px;" name="idLoaiTour">
                        <option>Loại tour</option>
                        @foreach (var item in new DAPMDuLich.Models.mapLoaiTour().DanhSach())
                        {
                            <option value="@item.ID" @Html.Raw(item.ID == (int?)ViewBag.idLoaiTour ? "selected" : "")>@item.Ten</option>
                        }
                    </select>
                </div>
                <!-- Tỉnh -->
                <div class="col-2" style="padding: 0px 10px; flex: 1;">
                    <select style="width: 100%; height: 35px;" name="tinh">
                        <option>Tất cả tỉnh</option>
                        @foreach (var item in new DAPMDuLich.Models.mapTinhThanh().DanhSach())
                        {
                            <option value="@item.ID_Tinh" @Html.Raw(item.ID_Tinh == (int?)ViewBag.tinh ? "selected" : "")>@item.Ten</option>
                        }
                    </select>
                </div>
                <!-- Mức giá -->
                <div class="col-2" style="padding: 0px 10px; flex: 1;">
                    <select style="width: 100%; height: 35px;" name="mucGia">
                        <option>Tất cả mức giá</option>
                        @foreach (var item in new DAPMDuLich.Models.mapMucGia().DanhSach())
                        {
                            <option value="@item.ID" @Html.Raw(item.ID == (int?)ViewBag.mucGia ? "selected" : "")>@item.Gia </option>
                        }
                    </select>
                </div>
                <!-- Nút submit -->
                <div class="col-2" style="padding: 0px 10px; flex: 1;">
                    <button type="submit" style="width: 100%; height: 35px; background: green; border: none; color: white; font-size: 13pt;">Tìm kiếm</button>
                </div>
            </form>
        </div>
    </div>
</div>
<!-- Hang 1 -->
<div style="display: flex; flex-wrap: wrap; gap: 20px;">
    @foreach (var item in Model)
    {
        <a href="@Url.Action("DetailTour", "DetailTour", new { id = item.ID })" style="text-decoration: none; color: inherit; flex: 1 1 calc(33.333% - 20px);">
            <div class="tour-card" style="box-shadow: rgba(0, 0, 0, 0.24) 0px 3px 8px; padding: 10px; border-radius: 10px; margin-bottom: 20px; display: flex; flex-direction: column; justify-content: space-between; height: 100%;">
                <div style="width: 100%; height: 400px; overflow: hidden; border-radius: 10px;">
                    <img src="@item.HinhAnh" alt="Tour Image" style="width: 100%; height: 100%; object-fit: cover;">
                </div>
                <div class="tour-info" style="padding: 10px; flex-grow: 1;">
                    <h2 style="font-size: 20px; margin: 10px 0;">@item.TieuDe</h2>
                    <p style="margin: 5px 0;"><strong>Số ngày đi :</strong> @item.TripStart</p>
                    <p style="margin: 5px 0;"><strong>Số ngày về:</strong> @item.TripEnd</p>
                    <p style="margin: 5px 0;"><strong>Số người tối đa:</strong> @item.SoNguoiToiDa</p>
                    <p style="margin: 5px 0;"><strong>Phương tiện:</strong> @item.PhuongTien</p>
                    <p style="margin: 5px 0;"><strong>Địa điểm:</strong> @item.DiaDiem</p>
                    <p style="margin: 5px 0;"><strong>Giá tour:</strong> @(Convert.ToDecimal(item.GiaTour).ToString("0.##")) USD</p>
                </div>
                <button style="padding: 10px 20px; background-color: #ffc700; border: none; border-radius: 5px; cursor: pointer; align-self: flex-end;">Chi tiết</button>
            </div>
        </a>
    }
</div>
<div id="gtco-counter" class="gtco-section">
    <div class="gtco-container">
        <div class="row">
            <div class="col-md-8 col-md-offset-2 text-center gtco-heading animate-box">
                <h2>Our Success</h2>
                <p>Besides, she is willing to go in the whole of the flight of a hard life worthy of the trouble of bringing against berate himself. And he hates from any pain her.</p>
            </div>
        </div>
        <div class="row">
            <div class="col-md-3 col-sm-6 animate-box" data-animate-effect="fadeInUp">
                <div class="feature-center">
                    <span class="counter js-counter" data-from="0" data-to="196" data-speed="5000" data-refresh-interval="50">100</span>
                    <span class="counter-label">Destination</span>
                </div>
            </div>
            <div class="col-md-3 col-sm-6 animate-box" data-animate-effect="fadeInUp">
                <div class="feature-center">
                    <span class="counter js-counter" data-from="0" data-to="97" data-speed="5000" data-refresh-interval="50">1998</span>
                    <span class="counter-label">Hotels</span>
                </div>
            </div>
            <div class="col-md-3 col-sm-6 animate-box" data-animate-effect="fadeInUp">
                <div class="feature-center">
                    <span class="counter js-counter" data-from="0" data-to="12402" data-speed="5000" data-refresh-interval="50">2000</span>
                    <span class="counter-label">Travelers</span>
                </div>
            </div>
            <div class="col-md-3 col-sm-6 animate-box" data-animate-effect="fadeInUp">
                <div class="feature-center">
                    <span class="counter js-counter" data-from="0" data-to="12202" data-speed="5000" data-refresh-interval="50">1092</span>
                    <span class="counter-label">Happy Customer</span>
                </div>
            </div>
        </div>
    </div>
</div>
<footer style="background-color: #6B9BC2; padding: 40px 0 30px 0; color: white; font-family: Arial, sans-serif; max-height: 550px; overflow: hidden;">
    <div class="container" style="width: 90%; margin: 0 auto;">
        <div class="row" style="display: flex; justify-content: space-between; align-items: flex-start;">

            <!-- Logo và thông tin thương hiệu -->
            <div class="footer-logo" style="flex: 1;">
                <img src="https://saigontourist.net/images/logo.png" alt="Logo Saigontourist" style="max-width: 150px; margin-bottom: 20px;">
                <p style="font-size: 16px; line-height: 1.8;">
                    Lữ hành Saigontourist, thương hiệu lữ hành hàng đầu Việt Nam.<br>
                    Địa chỉ: 828 Sư Vạn Hạnh, Quận 10, TP. Hồ Chí Minh<br>
                    Email: info@saigontourist.com<br>
                    Số điện thoại: 1800 123 456
                </p>
                <!-- Thêm biểu tượng giải thưởng hoặc thành tích -->
                <!--<div class="awards" style="margin-top: 20px;">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/5/55/Trophy_icon_yellow.svg/512px-Trophy_icon_yellow.svg.png" alt="Award" style="width: 30px; margin-right: 10px;">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/8/8d/Gold_star_icon.svg/1024px-Gold_star_icon.svg.png" alt="Award" style="width: 30px; margin-right: 10px;">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/e/e6/Key_icon_yellow.svg/1024px-Key_icon_yellow.svg.png" alt="Award" style="width: 30px;">
                </div>-->
            </div>

            <!-- Cột Dịch vụ -->
            <div class="footer-column" style="flex: 1;">
                <h3 style="font-size: 18px; border-bottom: 2px solid white; padding-bottom: 10px;">Dịch vụ</h3>
                <ul style="list-style: none; padding: 0; margin-top: 15px;">
                    <li style="margin-bottom: 10px;"><a href="#" style="color: white; text-decoration: none;">Tour trong nước</a></li>
                    <li style="margin-bottom: 10px;"><a href="#" style="color: white; text-decoration: none;">Tour ngoài nước</a></li>
                    <li style="margin-bottom: 10px;"><a href="#" style="color: white; text-decoration: none;">Các kiểu tour</a></li>
                    <li style="margin-bottom: 10px;"><a href="#" style="color: white; text-decoration: none;">Dịch vụ khách sạn</a></li>
                </ul>
            </div>

            <!-- Cột Chăm sóc khách hàng -->
            <div class="footer-column" style="flex: 1;">
                <h3 style="font-size: 18px; border-bottom: 2px solid white; padding-bottom: 10px;">Chăm sóc khách hàng</h3>
                <ul style="list-style: none; padding: 0; margin-top: 15px;">
                    <li style="margin-bottom: 10px;"><a href="#" style="color: white; text-decoration: none;">Hỗ trợ trực tuyến</a></li>
                    <li style="margin-bottom: 10px;"><a href="#" style="color: white; text-decoration: none;">Liên hệ</a></li>
                    <li style="margin-bottom: 10px;"><a href="#" style="color: white; text-decoration: none;">Chính sách hoàn tiền</a></li>
                    <li style="margin-bottom: 10px;"><a href="#" style="color: white; text-decoration: none;">Điều khoản dịch vụ</a></li>
                </ul>
            </div>

            <!-- Form đăng ký tư vấn miễn phí -->
            <div class="footer-column" style="flex: 1;">
                <h3 style="font-size: 18px; border-bottom: 2px solid white; padding-bottom: 10px;">Đăng ký tư vấn miễn phí</h3>
                <form action="#" method="post" style="margin-top: 15px;">
                    <div style="margin-bottom: 10px;">
                        <input type="text" id="name" name="name" placeholder="Nhập họ tên của bạn" style="width: 100%; padding: 10px; border: none; border-radius: 5px;">
                    </div>
                    <div style="margin-bottom: 10px;">
                        <input type="email" id="email" name="email" placeholder="Nhập email của bạn" style="width: 100%; padding: 10px; border: none; border-radius: 5px;">
                    </div>
                    <div style="margin-bottom: 10px;">
                        <input type="text" id="phone" name="phone" placeholder="Nhập số điện thoại của bạn" style="width: 100%; padding: 10px; border: none; border-radius: 5px;">
                    </div>
                    <button type="submit" style="background-color: #FFD700; color: #03256C; padding: 10px 20px; border: none; border-radius: 5px; font-size: 16px; cursor: pointer;">Đăng ký</button>
                </form>
            </div>
            <div class="col-md-6 col-sm-12 col-xs-12 wrapbox-iframe-contact boxContact-sticky">

                <div class="box-map">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.473853035941!2d106.6659678145891!3d10.774973292322516!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31752f3ae5901877%3A0x42c37972de865906!2zODI4IFPGsCBW4bqhbiBI4bqhbmgsIFBoxrDhu51uZyAxMiwgUXXhuq1uIDEwLCBUaMOgbmggcGjhu5EgSOG7kyBDaMOtIE1pbmgsIFZp4buHdCBOYW0!5e0!3m2!1svi!2s!4v1668591538078!5m2!1svi!2s" width="800" height="480" frameborder="0" style="border:0;" allowfullscreen="" aria-hidden="false" tabindex="0"></iframe>
                </div>
            </div>
        </div>
    </div>
</footer>
<hr />






