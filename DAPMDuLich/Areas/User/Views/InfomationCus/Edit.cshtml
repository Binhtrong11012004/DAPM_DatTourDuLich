@model DAPMDuLich.Models.TaiKhoan

@{
    ViewBag.Title = "Chỉnh sửa thông tin cá nhân";
    Layout = "~/Areas/User/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/CSS/animate.css" />
<link rel="stylesheet" href="~/CSS/bootstrap.css" />
<link rel="stylesheet" href="~/CSS/icomoon.css" />
<link rel="stylesheet" href="~/CSS/owl.carousel.min.css" />
<link rel="stylesheet" href="~/CSS/owl.theme.default.min.css" />
<link rel="stylesheet" href="~/CSS/style.css" />

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-lg border-light rounded">
                <div class="card-header text-center">
                    <h3 class="text-uppercase font-weight-bold" style="color: #000000;">Chỉnh sửa thông tin cá nhân</h3>
                </div>
                <div class="card-body">
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()

                        <!-- Tên Đăng Nhập -->
                        <div class="form-group">
                            <label for="TenDangNhap" class="font-weight-semibold">Tên Đăng Nhập</label>
                            <p class="form-control-plaintext">@Html.DisplayFor(model => model.TenDangNhap)</p>
                        </div>

                        <!-- Họ Tên -->
                        <div class="form-group">
                            <label for="TenHienThi" class="font-weight-semibold">Họ Tên</label>
                            @Html.EditorFor(model => model.TenHienThi, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.TenHienThi, "", new { @class = "text-danger" })
                        </div>

                        <!-- Mật khẩu -->
                        <div class="form-group">
                            <label for="MatKhau" class="font-weight-semibold">Mật khẩu</label>
                            @Html.EditorFor(model => model.MatKhau, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.MatKhau, "", new { @class = "text-danger" })
                        </div>

                        <!-- Số điện thoại -->
                        <div class="form-group">
                            <label for="SoDienThoai" class="font-weight-semibold">Số điện thoại</label>
                            @Html.EditorFor(model => model.SoDienThoai, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.SoDienThoai, "", new { @class = "text-danger" })
                        </div>

                        <!-- Địa chỉ -->
                        <div class="form-group">
                            <label for="DiaChi" class="font-weight-semibold">Địa chỉ</label>
                            @Html.EditorFor(model => model.DiaChi, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.DiaChi, "", new { @class = "text-danger" })
                        </div>

                        <!-- Email -->
                        <div class="form-group">
                            <label for="Email" class="font-weight-semibold">Email của bạn</label>
                            @Html.EditorFor(model => model.Email, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.Email, "", new { @class = "text-danger" })
                        </div>

                        <!-- Số tiền hiện có -->
                        <div class="form-group">
                            <label for="Tien" class="font-weight-semibold">Số tiền hiện có</label>
                            <p class="form-control-plaintext">@Html.DisplayFor(model => model.Tien) VND</p>
                        </div>

                        <!-- Action Buttons -->
                        <div class="form-group text-center">
                            <button type="submit" class="btn btn-lg btn-success rounded-pill px-5">Lưu thay đổi</button>
                            @Html.ActionLink("Trở lại", "Details", null, new { @class = "btn btn-lg btn-outline-secondary ml-3 rounded-pill px-5" })
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        font-family: 'Arial', sans-serif;
        background-color: #f8f9fa;
        margin: 0;
        padding: 0;
    }

    .card {
        border-radius: 12px;
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
        background-color: #fff;
    }

    .card-header {
        background-color: transparent; /* Transparent background */
        color: #000000; /* Black text color */
        padding: 20px;
        font-size: 1.5rem;
        text-transform: uppercase;
        font-weight: bold;
        border-top-left-radius: 12px;
        border-top-right-radius: 12px;
    }

    .card-body {
        padding: 30px;
    }

    .form-group {
        margin-bottom: 25px;
    }

        .form-group label {
            font-size: 1.1rem;
            color: #333;
            font-weight: 600;
        }

    .form-control {
        border-radius: 10px;
        padding: 12px;
        font-size: 1rem;
        border: 1px solid #ddd;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
    }

        .form-control:focus {
            border-color: #007bff;
            box-shadow: 0 0 10px rgba(0, 123, 255, 0.5);
        }

    .form-control-plaintext {
        padding: 12px;
        background-color: #f7f7f7;
        border-radius: 10px;
    }

    .btn {
        padding: 12px 25px;
        font-size: 1.1rem;
        text-align: center;
        transition: background-color 0.3s, transform 0.2s;
        border-radius: 25px;
    }

        .btn:hover {
            transform: translateY(-3px);
        }

    .btn-success {
        background-color: #28a745;
        color: white;
        border: none;
    }

        .btn-success:hover {
            background-color: #218838;
        }

    .btn-outline-secondary {
        background-color: #f8f9fa;
        color: #333;
        border: 1px solid #ccc;
    }

        .btn-outline-secondary:hover {
            background-color: #e2e6ea;
        }

    .ml-3 {
        margin-left: 20px;
    }

    .text-danger {
        font-size: 0.9rem;
        color: #dc3545;
        margin-top: 5px;
    }
</style>
