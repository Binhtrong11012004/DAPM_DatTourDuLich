@model DAPMDuLich.Models.ViewModel.BookingViewModel

@{
    ViewBag.Title = "Create";
    Layout = "~/Areas/User/Views/Shared/LayoutCus.cshtml";
}

<link rel="stylesheet" href="~/CSS/animate.css" />
<link rel="stylesheet" href="~/CSS/bootstrap.css" />
<link rel="stylesheet" href="~/CSS/icomoon.css" />
<link rel="stylesheet" href="~/CSS/owl.carousel.min.css" />
<link rel="stylesheet" href="~/CSS/owl.theme.default.min.css" />
<link rel="stylesheet" href="~/CSS/style.css" />

@using (Html.BeginForm("Create", "Booking", Model, FormMethod.Post))
{
    <div class="container py-5">
        <div class="row">
            <!-- Tour Information -->
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm rounded-3 border-0">
                    <div class="card-body">
                        <h3 class="text-center mb-4 text-primary">Thông tin tour</h3>
                        <div class="mb-3">
                            <label class="fw-bold text-primary">Tên tour:</label>
                            <p>@Model.TieuDe</p>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold text-primary">Mô tả:</label>
                            <p>@Model.BaiViet</p>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold text-primary">Ngày đi:</label>
                            <p>@Model.TripStart</p>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold text-primary">Ngày về:</label>
                            <p>@Model.TripEnd</p>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold text-primary">Số người tối đa:</label>
                            <p>@Model.SoNguoiToiDa</p>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold text-primary">Phương tiện:</label>
                            <p>@Model.PhuongTien</p>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold text-primary">Giá tour:</label>
                            <p>@String.Format("{0:0.##}", Model.GiaTour) USD</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- User Information -->
            <div class="col-md-6">
                <div class="card shadow-sm rounded-3 border-0">
                    <div class="card-body">
                        <h3 class="text-center mb-4 text-primary">Thông tin của bạn</h3>
                        <div class="mb-3">
                            <label class="fw-bold text-primary">Tên của bạn:</label>
                            <p>@Model.HoTen</p>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold text-primary">Email:</label>
                            <p>@Model.Email</p>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold text-primary">Số lượng người:</label>
                            @Html.EditorFor(model => model.TravelerCount, new { htmlAttributes = new { @class = "form-control rounded-3" } })
                            @Html.ValidationMessageFor(model => model.TravelerCount, "", new { @class = "text-danger" })
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg rounded-3 shadow-lg" style="background-color: #4CAF50; border: none; transition: all 0.3s ease;">Xác nhận giữ chỗ</button>
                            <a href="@Url.Action("Home", "Home")" class="btn btn-danger btn-lg rounded-3 shadow-lg" style="background-color: #F44336; color: white; transition: all 0.3s ease;">Hủy</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
