@model IEnumerable<DAPMDuLich.Models.TourDuLich>

@{
    ViewBag.Title = "Danh Sách Tour Chờ Duyệt";
    Layout = "~/Areas/Admin/Views/Shared/layoutadmin.cshtml";
}

<div class="page-header">
    <h1>DANH SÁCH TOUR ĐANG CHỜ DUYỆT</h1>
</div>



<div class="table-container">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th class="text-center">#</th>
                <th class="text-center">Công Ty</th>
                <th class="text-center">Tour ID</th>
                <th class="text-center">Trạng thái Duyệt</th>
                <th class="text-center">Hành Động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="text-center align-middle">@item.ID</td>
                    <td class="align-middle">@item.Contributor.ContributorNickName</td>
                    <td class="text-center align-middle">@item.ID</td>
                    <td class="text-center align-middle">
                        @if (item.Status == "N")
                        {
                            <span class="badge bg-warning text-dark">Đang chờ duyệt bài...</span>
                        }
                    </td>
                    <td class="text-center align-middle">
                        <a href="@Url.Action("Details", "AwaitingApprovalTour", new { id = item.ID })" class="btn btn-info btn-sm mr-2">
                            <i class="fas fa-eye"></i> Xem chi tiết
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Font Awesome for icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" integrity="sha384-k6RqeWeci5ZR/Lv4MR0sA0FfDOMnYbo0D1i63hxGdD6ld6/5rK9OMZlrw5rYc8a8" crossorigin="anonymous">

<!-- Link Google Fonts for Roboto -->
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">

<!-- CSS -->
<style>
    /* Apply Roboto font to all text */
    * {
        font-family: 'Roboto', sans-serif;
    }

    /* Page background */
    body {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
    }

    /* Page header */
    /* Page header */
    .page-header {
        display: flex; /* Sử dụng Flexbox */
        justify-content: center; /* Căn giữa theo chiều ngang */
        align-items: center; /* Căn giữa theo chiều dọc */
        color: #2c3e50; /* Màu chữ */
        font-weight: bold; /* Đặt chữ in đậm */
        font-size: 26px; /* Kích thước chữ */
        margin-top: 20px; /* Khoảng cách trên */
        margin-bottom: 30px; /* Khoảng cách dưới */
        padding-top: 20px; /* Khoảng cách trên cho padding */
    }

        /* Đảm bảo sử dụng Roboto và in đậm cho tiêu đề */
        .page-header h1 {
            font-family: 'Roboto', sans-serif !important; /* Font Roboto */
            font-weight: bold; /* Chữ in đậm */
        }

    /* "Thêm Tour Mới" button */
    .btn-primary {
        background-color: #3498db;
        border-color: #3498db;
        color: #fff;
        border-radius: 8px;
        padding: 12px 25px;
        font-size: 16px;
        font-weight: 500;
        transition: background-color 0.3s ease;
        display: inline-block;
        text-align: left;
        font-family: 'Roboto', sans-serif;
    }

        .btn-primary:hover {
            background-color: #2980b9;
            transform: scale(1.05);
        }

    /* Table container */
    .table-container {
        width: 100%;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
        background-color: #ffffff;
    }

    .table {
        width: 100%;
        margin-bottom: 0;
    }

        .table th, .table td {
            padding: 16px;
            text-align: center;
        }

        .table thead th {
            background-color: #f5f5f5;
            font-weight: 600;
            color: #333;
        }

        .table tbody tr {
            border-top: 1px solid #e5e5e5;
        }

            .table tbody tr:hover {
                background-color: #f0f8ff;
            }

    /* Action buttons */
    .btn-info {
        background-color: #007bff;
        border-color: #007bff;
        color: #fff;
        border-radius: 6px;
        padding: 10px 20px;
        font-size: 14px;
        font-weight: bold;
        transition: all 0.3s ease;
    }

        .btn-info:hover {
            background-color: #0056b3;
            box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.15);
        }

    /* Badge styles */
    .badge {
        font-size: 0.9rem;
        padding: 5px 10px;
        border-radius: 20px;
    }

    /* Improve table hover effect */
    .table tbody tr:hover {
        background-color: #f0f8ff;
    }
</style>
