@model IEnumerable<DAPMDuLich.Models.LoaiTour>
@{
    ViewBag.Title = "Danh Sách Loại Tour";
    Layout = "~/Areas/Admin/Views/Shared/layoutadmin.cshtml";
}

<div class="page-header">
    <h2>Danh Sách Loại Tour</h2>
</div>

<p>
    <a href="@Url.Action("Create", "TourType")" class="btn btn-primary">Thêm Loại Tour Mới</a>
</p>

<div class="table-container">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th class="text-center">ID</th>
                <th>Tên Loại Tour</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="text-center align-middle">@item.ID</td>
                    <td class="align-middle">
                        <i class="fas fa-map-marker-alt text-primary mr-2"></i> @item.Ten
                    </td>
                    <td class="text-center align-middle">
                        <a href="@Url.Action("Edit", "TourType", new { area = "Admin", id = item.ID })" class="btn btn-warning btn-sm mr-2">
                            <i class="fas fa-edit"></i> Chỉnh sửa
                        </a>
                        <a href="@Url.Action("Delete", "TourType", new { area = "Admin", id = item.ID })" class="btn btn-danger btn-sm" onclick="return confirm('Bạn có muốn xóa loại tour này?');">
                            <i class="fas fa-trash-alt"></i> Xóa
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Font Awesome for icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" integrity="sha384-k6RqeWeci5ZR/Lv4MR0sA0FfDOMnYbo0D1i63hxGdD6ld6/5rK9OMZlrw5rYc8a8" crossorigin="anonymous">

<!-- Link Google Fonts for Roboto -->
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">

<!-- CSS -->
<style>
    /* Apply Roboto font to all text */
    * {
        font-family: 'Roboto', sans-serif;
    }

    /* Page background */
    body {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
    }

    /* Page title */
    .page-header {
        text-align: center;
        color: #2c3e50;
        font-weight: 700;
        font-size: 26px;
        margin-top: 20px;
        margin-bottom: 30px;
        padding-top: 20px;
        
    }
        .page-header h2 {
            font-family: 'Roboto', sans-serif !important;
        }
    /* "Thêm Loại Tour Mới" button */
    .btn-primary {
        background-color: #3498db;
        border-color: #3498db;
        color: #fff;
        border-radius: 8px;
        padding: 12px 25px;
        font-size: 16px;
        font-weight: 500;
        transition: background-color 0.3s ease;
        display: inline-block;
        text-align: left;
        font-family: 'Roboto', sans-serif;
    }

        .btn-primary:hover {
            background-color: #2980b9;
            transform: scale(1.05);
        }

    /* Table container */
    .table-container {
        width: 100%;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
        background-color: #ffffff;
    }

    .table {
        width: 100%;
        margin-bottom: 0;
    }

        .table th, .table td {
            padding: 16px;
            text-align: center;
        }

        .table thead th {
            background-color: #f5f5f5;
            font-weight: 600;
            color: #333;
        }

        .table tbody tr {
            border-top: 1px solid #e5e5e5;
        }

            .table tbody tr:hover {
                background-color: #f0f8ff;
            }

    /* Action buttons */
    .btn-warning, .btn-danger {
        border-radius: 6px;
        padding: 10px 20px;
        font-size: 14px;
        font-weight: bold;
        color: #fff;
        transition: all 0.3s ease;
    }

    .btn-warning {
        background-color: #ff9800;
        border-color: #ff9800;
    }

        .btn-warning:hover {
            background-color: #e68900;
            box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.15);
        }

    .btn-danger {
        background-color: #ff5252;
        border-color: #ff5252;
    }

        .btn-danger:hover {
            background-color: #e04848;
            box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.15);
        }
</style>
