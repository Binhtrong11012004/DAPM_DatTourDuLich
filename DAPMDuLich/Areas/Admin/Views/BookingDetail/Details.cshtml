@model DAPMDuLich.Models.DatTourChiTiet
@{
    ViewBag.Title = "Chi Tiết Đặt Tour";
    Layout = "~/Areas/Admin/Views/Shared/layoutadmin.cshtml";
}

<div class="container mt-5">
    <div class="d-flex justify-content-center mb-4">
        <h2 class="font-weight-bold">Chi Tiết Đặt Tour</h2>
    </div>

    <!-- Thông tin Booking -->
    <div class="card shadow-sm mb-5 border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Thông Tin Booking</h5>
            <i class="fas fa-book"></i>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <p><strong>ID Booking:</strong> @Html.DisplayFor(model => model.DatTour.BookingID)</p>
                    <p><strong>Tên Khách Hàng:</strong> @Html.DisplayFor(model => model.DatTour.TaiKhoan.TenHienThi)</p>
                </div>
                <div class="col-md-6">
                    <p><strong>Tên Công Ty (Contributor):</strong> @Html.DisplayFor(model => model.DatTour.Contributor.ContributorNickName)</p>
                    <p><strong>Ngày Tạo:</strong> @Html.DisplayFor(model => model.DatTour.CreateAt)</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Thông tin Thanh Toán -->
    <div class="card shadow-sm mb-5 border-0">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Thông Tin Thanh Toán</h5>
            <i class="fas fa-credit-card"></i>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <p>
                        <strong>Trạng Thái Thanh Toán:</strong>
                        @(Model.DatTour.ThanhToan.HasValue
                            ? (Model.DatTour.ThanhToan.Value ? "Đã thanh toán" : "Chưa thanh toán")
                            : "Không xác định")
                    </p>
                    <p><strong>Mã Thanh Toán:</strong> @Html.DisplayFor(model => model.DatTour.MaThanhToan)</p>
                </div>
                <div class="col-md-6">
                    <p><strong>Giá Tour:</strong> @String.Format("{0:C2}", Model.Price)</p>
                    <p><strong>Số Lượng Người:</strong> @Model.TravelerCount</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Nút quay lại -->
    <div class="text-center mt-4">
        @Html.ActionLink("Quay về danh sách", "List", "Booking", null, new { @class = "btn btn-primary btn-lg shadow" })
    </div>
</div>

<!-- Optional: Add some custom styling for better appearance -->
<style>
    .container {
        max-width: 900px;
    }

    .card {
        border-radius: 10px;
    }

    .card-header {
        font-size: 1.1rem;
        font-weight: bold;
    }

    .btn {
        padding: 10px 30px;
        font-size: 1rem;
        border-radius: 5px;
    }
</style>
